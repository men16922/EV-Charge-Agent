# Dockerfile.web
# Container for the EV-Charge Flask web app (UI + ADK/Gemini agent).
# Separate from the root Dockerfile, which builds the MCP Toolbox image.
FROM python:3.12-slim

WORKDIR /app

# Install Python dependencies first (better layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# App code: Flask agent, local MCP fallback module, web templates, static assets
COPY agent.py mcp_server_local.py ./
COPY templates ./templates
COPY static ./static

# Cloud Run injects PORT (defaults to 8080); agent.py reads os.environ['PORT'].
ENV PORT=8080
EXPOSE 8080

CMD ["python3", "agent.py"]
