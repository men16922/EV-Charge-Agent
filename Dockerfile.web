# Dockerfile.web
# Container for the Smart-EV Flask web app (UI + ADK/Gemini agent).
# Multi-stage: build the React (Vite) frontend with Node, then serve it (and the
# JSON/SSE APIs) from the Python/Flask runtime — one image, one Cloud Run service.

# --- Stage 1: build the React (Vite) bundle → /dist ---
FROM node:20-slim AS web
WORKDIR /web
COPY frontend/package*.json ./
RUN npm ci
COPY frontend/ ./
RUN npm run build           # vite outDir '../dist' → /dist

# --- Stage 2: Python/Flask runtime ---
FROM python:3.12-slim
WORKDIR /app

# Install Python dependencies first (better layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# App code: Flask agent, local MCP fallback module, legacy templates, static assets
COPY agent.py mcp_server_local.py ./
COPY templates ./templates
COPY static ./static

# Built React app (served by agent.py from ./dist)
COPY --from=web /dist ./dist

# Cloud Run injects PORT (defaults to 8080); agent.py reads os.environ['PORT'].
ENV PORT=8080
EXPOSE 8080

CMD ["python3", "agent.py"]
